# Bank2QBO required environment variables
#
# Copy to .env (gitignored) and fill in values.
# Used by: agents/intake.py, agents/processor.py, agents/deliverer.py,
#          bin/concierge_serve.py, bin/daily_digest.py
#
# Load via:  set -a; source .env; set +a; python3 bin/concierge_serve.py

# ── Telegram (Klau's alert channel) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Resend (transactional email — customer welcome + delivery) ──────────────
RESEND_API_KEY=
# IMPORTANT: This domain must be VERIFIED in Resend (verified-sender requirement).
# bank2qbo.com is unverified until you complete DNS records — until then,
# point this at a verified domain you already own (e.g., mundallcfreight.com).
RESEND_FROM_EMAIL=claudio@bank2qbo.com
RESEND_FROM_NAME=Claudio at Bank2QBO

# ── Stripe (revenue lookup + webhook receiver) ──────────────────────────────
STRIPE_SECRET_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks/<wh_id>/signing
# REQUIRED for /webhook/stripe; without it concierge_serve.py rejects all
# webhook requests with HTTP 503 to prevent spoofing the conversions table.
STRIPE_WEBHOOK_SECRET=

# ── PostHog (landing analytics) — currently disabled in landing/index.html ──
# Re-enable by uncommenting the posthog.init() call in landing/index.html
# and replacing 'phc_REPLACE_ME_WITH_REAL_KEY' with the key below.
POSTHOG_API_KEY=

# ── Anthropic (used by processor.py via local `claude` CLI on Max plan) ─────
# No env var required — the Claude CLI inherits Klau's logged-in session.
# Override only if needing a different model or API-mode access.
# ANTHROPIC_API_KEY=
